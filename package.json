{
  "name": "softhouse-central",
  "private": true,
  "version": "0.1.0",
  "description": "Sistema central para operação e escala de softhouse",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm --workspace apps/api run dev",
    "build:api": "npm --workspace apps/api run build",
    "start:api": "npm --workspace apps/api run start"
  }
}
